port: 7880
log_level: info
keys:
  devkey: secret

rtc:
  use_external_ip: false
  tcp_port: 7881
  port_range_start: 51000
  port_range_end: 51100

# TURN/TLS for remote access (Tailscale or mkcert)
turn:
  enabled: true
  domain: ${HTTPS_DOMAIN}
  tls_port: ${TURN_TLS_PORT}
  udp_port: 3478
  cert_file: /etc/livekit/certs/server.crt
  key_file: /etc/livekit/certs/server.key
  relay_range_start: 30000
  relay_range_end: 30100
  external_tls: false
